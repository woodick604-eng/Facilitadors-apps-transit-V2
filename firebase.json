{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, no-cache, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "no-referrer"
          },
          {
            "key": "Permissions-Policy",
            "value": "geolocation=(), microphone=(self \"https://dictat-atenea-t06.web.app\" \"https://la4-sintomatologia-actes.web.app\" \"https://simptomatologia.web.app\" \"https://dictat-minutes.web.app\" \"https://processador-imatges-accidents.web.app\"), camera=(self \"https://dictat-atenea-t06.web.app\" \"https://la4-sintomatologia-actes.web.app\" \"https://simptomatologia.web.app\" \"https://processador-imatges-accidents.web.app\")"
          },
          {
            "key": "X-Privacy-Policy",
            "value": "zero-data-retention; encrypted-transit=TLS1.3; encrypted-rest=AES256; no-ai-training=true"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob:; connect-src 'self' https://*.googleapis.com wss://*.firebaseio.com https://*.firebaseio.com; manifest-src 'self'; worker-src 'self'; frame-src https://*.web.app https://*.firebaseapp.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self';"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}